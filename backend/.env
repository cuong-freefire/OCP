# --- Added Auth runtime defaults ---
# Non-secret defaults required by feat-auth. Existing secret values above are preserved.

# Backend HTTP port.
PORT=5050

# REST API prefix.
API_PREFIX=/api

# Exact CRA frontend origin allowed by CORS with credentials.
FRONTEND_ORIGIN=http://localhost:3000

# Access token cookie name.
COOKIE_ACCESS_NAME=ocp_access_token

# Refresh token cookie name.
COOKIE_REFRESH_NAME=ocp_refresh_token

# Cookie SameSite policy for same-site MVP.
COOKIE_SAME_SITE=lax

# false for local HTTP dev, true for production HTTPS.
COOKIE_SECURE=false

# Email verification OTP expiry.
EMAIL_OTP_EXPIRES_MINUTES=10

# Email verification OTP max failed attempts.
EMAIL_OTP_MAX_FAILED_ATTEMPTS=5

# Email verification OTP resend cooldown.
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60

# Reset password OTP expiry.
RESET_OTP_EXPIRES_MINUTES=10

# Reset password OTP max failed attempts.
RESET_OTP_MAX_FAILED_ATTEMPTS=5

# Reset password OTP resend cooldown.
RESET_OTP_RESEND_COOLDOWN_SECONDS=60

# Nodemailer SMTP host for Gmail/App Password setup. Change if using another SMTP provider.
SMTP_HOST=smtp.gmail.com

# Nodemailer SMTP port.
SMTP_PORT=587

# true for implicit TLS port 465, false for STARTTLS ports like 587.
SMTP_SECURE=false

# Sender display name.
SMTP_FROM_NAME=OCP

# Sender email. Code may fallback to SMTP_USER if variable expansion is not supported.
SMTP_FROM_EMAIL=tandava2005@gmail.com

# --- Added Auth security defaults ---
# Non-secret values required by feat-auth.

# Access token lifetime.
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token lifetime.
JWT_REFRESH_EXPIRES_IN=7d

# bcrypt salt rounds.
BCRYPT_SALT_ROUNDS=12
