model Quiz {
  id               String           @id @default(uuid()) @db.Char(36)
  courseId         String           @map("course_id") @db.Char(36)
  lessonId         String?          @map("lesson_id") @db.Char(36)
  title            String           @db.VarChar(255)
  description      String?          @db.Text
  timeLimitMinutes Int?             @map("time_limit_minutes")
  passingScore     Int              @default(70) @map("passing_score")
  status           String           @default("active") @db.VarChar(50)
  questions        QuizQuestion[]
  submissions      QuizSubmission[]
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@index([courseId, status], map: "idx_quizzes_course_status")
  @@index([lessonId], map: "idx_quizzes_lesson")
  @@map("quizzes")
}

model QuizQuestion {
  id            String   @id @default(uuid()) @db.Char(36)
  quizId        String   @map("quiz_id") @db.Char(36)
  quiz          Quiz     @relation(fields: [quizId], references: [id])
  questionText  String   @map("question_text") @db.Text
  questionType  String   @map("question_type") @db.VarChar(50)
  options       Json
  correctAnswer Json     @map("correct_answer")
  explanation   String?  @db.Text
  points        Int      @default(1)
  order         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([quizId, order], map: "idx_quiz_questions_quiz_order")
  @@map("quiz_questions")
}

model QuizSubmission {
  id          String   @id @default(uuid()) @db.Char(36)
  userId      String   @map("user_id") @db.Char(36)
  quizId      String   @map("quiz_id") @db.Char(36)
  quiz        Quiz     @relation(fields: [quizId], references: [id])
  answers     Json
  score       Int      @default(0)
  maxScore    Int      @default(0) @map("max_score")
  passed      Boolean  @default(false)
  startedAt   DateTime @map("started_at")
  submittedAt DateTime @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, quizId, submittedAt], map: "idx_quiz_submissions_user_quiz")
  @@index([quizId, submittedAt], map: "idx_quiz_submissions_quiz")
  @@map("quiz_submissions")
}

model FinalProject {
  id          String               @id @default(uuid()) @db.Char(36)
  courseId    String               @map("course_id") @db.Char(36)
  title       String               @db.VarChar(255)
  description String?              @db.Text
  startDate   DateTime             @map("start_date")
  endDate     DateTime             @map("end_date")
  status      String               @default("active") @db.VarChar(50)
  submissions ProjectSubmission[]
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  @@index([courseId], map: "idx_final_projects_course")
  @@map("final_projects")
}

model ProjectSubmission {
  id             String   @id @default(uuid()) @db.Char(36)
  userId         String   @map("user_id") @db.Char(36)
  finalProjectId String   @map("final_project_id") @db.Char(36)
  finalProject   FinalProject @relation(fields: [finalProjectId], references: [id])
  courseId       String   @map("course_id") @db.Char(36)
  repositoryUrl  String   @map("repository_url") @db.VarChar(500)
  demoUrl        String?  @map("demo_url") @db.VarChar(500)
  status         String   @default("PENDING") @db.VarChar(50)
  submittedLate  Boolean  @default(false) @map("submitted_late")
  attemptNumber  Int      @default(1) @map("attempt_number")
  isCurrent      Boolean  @default(true) @map("is_current")
  mentorNotes    String?  @map("mentor_notes") @db.Text
  submittedAt    DateTime @map("submitted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([userId, finalProjectId, isCurrent], map: "idx_project_submissions_user_current")
  @@index([userId, finalProjectId, submittedAt], map: "idx_project_submissions_user_history")
  @@map("project_submissions")
}