model Role {
  id        String   @id @default(uuid()) @db.Char(36)
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  users     User[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model User {
  id                 String                 @id @default(uuid()) @db.Char(36)
  roleId             String                 @map("role_id") @db.Char(36)
  role               Role                   @relation(fields: [roleId], references: [id])
  name               String                 @db.VarChar(255)
  email              String                 @unique @db.VarChar(255)
  avatarUrl          String?                @map("avatar_url") @db.VarChar(500)
  passwordHash       String?                @map("password_hash") @db.VarChar(255)
  emailVerified      Boolean                @default(false) @map("email_verified")
  status             String                 @default("pending_verification") @db.VarChar(50)
  deletedAt          DateTime?              @map("deleted_at")
  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  passwordResetTokens PasswordResetToken[]
  oauthAccounts      OAuthAccount[]
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  @@index([roleId, status], map: "idx_users_role_status")
  @@map("users")
}

model OAuthAccount {
  id                String   @id @default(uuid()) @db.Char(36)
  userId            String   @map("user_id") @db.Char(36)
  user              User     @relation(fields: [userId], references: [id])
  provider          String   @db.VarChar(50)
  providerUserId    String   @map("provider_user_id") @db.VarChar(255)
  providerEmail     String   @map("provider_email") @db.VarChar(255)
  providerName      String?  @map("provider_name") @db.VarChar(255)
  providerAvatarUrl String?  @map("provider_avatar_url") @db.VarChar(500)
  metadata          Json?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([provider, providerUserId], map: "idx_oauth_accounts_provider_user")
  @@unique([userId, provider], map: "idx_oauth_accounts_user_provider")
  @@index([provider, providerEmail], map: "idx_oauth_accounts_provider_email")
  @@map("oauth_accounts")
}

model RefreshToken {
  id                String    @id @default(uuid()) @db.Char(36)
  userId            String    @map("user_id") @db.Char(36)
  user              User      @relation(fields: [userId], references: [id])
  tokenHash         String    @unique @map("token_hash") @db.Char(64)
  expiresAt         DateTime  @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  replacedByTokenId String?   @map("replaced_by_token_id") @db.Char(36)
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([userId, expiresAt], map: "idx_refresh_tokens_user")
  @@map("refresh_tokens")
}

model EmailVerification {
  id             String    @id @default(uuid()) @db.Char(36)
  userId         String    @map("user_id") @db.Char(36)
  user           User      @relation(fields: [userId], references: [id])
  otpHash        String    @map("otp_hash") @db.Char(64)
  expiresAt      DateTime  @map("expires_at")
  usedAt         DateTime? @map("used_at")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedAt       DateTime? @map("locked_at")
  lastSentAt     DateTime  @map("last_sent_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([userId, expiresAt], map: "idx_email_verifications_user")
  @@index([userId, lastSentAt], map: "idx_email_verifications_resend")
  @@map("email_verifications")
}

model PasswordResetToken {
  id             String    @id @default(uuid()) @db.Char(36)
  userId         String    @map("user_id") @db.Char(36)
  user           User      @relation(fields: [userId], references: [id])
  otpHash        String    @map("otp_hash") @db.Char(64)
  expiresAt      DateTime  @map("expires_at")
  usedAt         DateTime? @map("used_at")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedAt       DateTime? @map("locked_at")
  lastSentAt     DateTime  @map("last_sent_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([userId, expiresAt], map: "idx_password_reset_tokens_user")
  @@index([userId, lastSentAt], map: "idx_password_reset_tokens_resend")
  @@map("password_reset_tokens")
}