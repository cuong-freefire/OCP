generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id        String   @id @default(uuid()) @db.Char(36)
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  users     User[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model User {
  id                  String               @id @default(uuid()) @db.Char(36)
  roleId              String               @map("role_id") @db.Char(36)
  role                Role                 @relation(fields: [roleId], references: [id])
  name                String               @db.VarChar(255)
  email               String               @unique @db.VarChar(255)
  avatarUrl           String?              @map("avatar_url") @db.VarChar(500)
  passwordHash        String?              @map("password_hash") @db.VarChar(255)
  emailVerified       Boolean              @default(false) @map("email_verified")
  status              String               @default("pending_verification") @db.VarChar(50)
  deletedAt           DateTime?            @map("deleted_at")
  refreshTokens       RefreshToken[]
  emailVerifications  EmailVerification[]
  passwordResetTokens PasswordResetToken[]
  oauthAccounts       OAuthAccount[]
  mentorAssignments   MentorAssignment[]   @relation("mentorAssignments")
  submissions         ProjectSubmission[]  @relation("submissions")
  projectReviews      ProjectReview[]      @relation("reviews")
  courseRevisions     CourseRevision[]     @relation("createdRevisions")
  courseReviews       CourseReview[]       @relation("reviewerReviews")
  ratings             Rating[]
  feedbacks           Feedback[]
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  @@index([roleId, status], map: "idx_users_role_status")
  @@map("users")
}

model OAuthAccount {
  id                String   @id @default(uuid()) @db.Char(36)
  userId            String   @map("user_id") @db.Char(36)
  user              User     @relation(fields: [userId], references: [id])
  provider          String   @db.VarChar(50)
  providerUserId    String   @map("provider_user_id") @db.VarChar(255)
  providerEmail     String   @map("provider_email") @db.VarChar(255)
  providerName      String?  @map("provider_name") @db.VarChar(255)
  providerAvatarUrl String?  @map("provider_avatar_url") @db.VarChar(500)
  metadata          Json?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([provider, providerUserId], map: "idx_oauth_accounts_provider_user")
  @@unique([userId, provider], map: "idx_oauth_accounts_user_provider")
  @@index([provider, providerEmail], map: "idx_oauth_accounts_provider_email")
  @@map("oauth_accounts")
}

model RefreshToken {
  id                String    @id @default(uuid()) @db.Char(36)
  userId            String    @map("user_id") @db.Char(36)
  user              User      @relation(fields: [userId], references: [id])
  tokenHash         String    @unique @map("token_hash") @db.Char(64)
  expiresAt         DateTime  @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  replacedByTokenId String?   @map("replaced_by_token_id") @db.Char(36)
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([userId, expiresAt], map: "idx_refresh_tokens_user")
  @@map("refresh_tokens")
}

model EmailVerification {
  id             String    @id @default(uuid()) @db.Char(36)
  userId         String    @map("user_id") @db.Char(36)
  user           User      @relation(fields: [userId], references: [id])
  otpHash        String    @map("otp_hash") @db.Char(64)
  expiresAt      DateTime  @map("expires_at")
  usedAt         DateTime? @map("used_at")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedAt       DateTime? @map("locked_at")
  lastSentAt     DateTime  @map("last_sent_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([userId, expiresAt], map: "idx_email_verifications_user")
  @@index([userId, lastSentAt], map: "idx_email_verifications_resend")
  @@map("email_verifications")
}

model PasswordResetToken {
  id             String    @id @default(uuid()) @db.Char(36)
  userId         String    @map("user_id") @db.Char(36)
  user           User      @relation(fields: [userId], references: [id])
  otpHash        String    @map("otp_hash") @db.Char(64)
  expiresAt      DateTime  @map("expires_at")
  usedAt         DateTime? @map("used_at")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedAt       DateTime? @map("locked_at")
  lastSentAt     DateTime  @map("last_sent_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([userId, expiresAt], map: "idx_password_reset_tokens_user")
  @@index([userId, lastSentAt], map: "idx_password_reset_tokens_resend")
  @@map("password_reset_tokens")
}

model Course {
  id                 String              @id @default(uuid()) @db.Char(36)
  title              String              @db.VarChar(255)
  slug               String              @unique @db.VarChar(255)
  description        String?             @db.Text
  price              Decimal             @default(0) @db.Decimal(15, 2)
  isPaid             Boolean             @default(false) @map("is_paid")
  status             String              @default("active") @db.VarChar(20)
  thumbnailUrl       String?             @map("thumbnail_url") @db.VarChar(500)
  categoryId         String?             @map("category_id") @db.Char(36)
  level              String?             @db.VarChar(30)
  publishedAt        DateTime?           @map("published_at")
  mentorAssignments  MentorAssignment[]
  projectSubmissions ProjectSubmission[]
  courseRevisions    CourseRevision[]
  ratings            Rating[]
  feedbacks          Feedback[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@index([categoryId, status], map: "idx_courses_category_status")
  @@map("courses")
}

model CourseSection {
  id          String   @id @default(uuid()) @db.Char(36)
  courseId    String   @map("course_id") @db.Char(36)
  title       String   @db.VarChar(255)
  description String?  @db.Text
  orderIndex  Int      @map("order_index")
  isActive    Boolean  @default(true) @map("is_active")
  lessons     Lesson[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([courseId, orderIndex], map: "uq_course_sections_order")
  @@index([courseId], map: "idx_course_sections_course")
  @@map("course_sections")
}

model Lesson {
  id              String        @id @default(uuid()) @db.Char(36)
  sectionId       String        @map("section_id") @db.Char(36)
  section         CourseSection @relation(fields: [sectionId], references: [id])
  title           String        @db.VarChar(255)
  content         String?       @db.LongText
  videoUrl        String?       @map("video_url") @db.VarChar(500)
  durationSeconds Int           @default(0) @map("duration_seconds")
  orderIndex      Int           @map("order_index")
  isPreview       Boolean       @default(false) @map("is_preview")
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@unique([sectionId, orderIndex], map: "uq_lessons_order")
  @@index([sectionId], map: "idx_lessons_section")
  @@map("lessons")
}

model CourseRevision {
  id           String        @id @default(uuid()) @db.Char(36)
  courseId     String        @map("course_id") @db.Char(36)
  course       Course        @relation(fields: [courseId], references: [id])
  mentorId     String        @map("mentor_id") @db.Char(36)
  mentor       User          @relation("createdRevisions", fields: [mentorId], references: [id])
  version      Int           @default(1)
  status       String        @default("DRAFT") @db.VarChar(20) // DRAFT, PENDING_REVIEW, APPROVED, REJECTED, PUBLISHED, SUPERSEDED
  notes        String?       @db.Text
  courseReview CourseReview?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([courseId, status], map: "idx_course_revisions_status")
  @@index([mentorId], map: "idx_course_revisions_mentor")
  @@map("course_revisions")
}

model CourseReview {
  id         String         @id @default(uuid()) @db.Char(36)
  revisionId String         @unique @map("revision_id") @db.Char(36)
  revision   CourseRevision @relation(fields: [revisionId], references: [id])
  reviewerId String         @map("reviewer_id") @db.Char(36)
  reviewer   User           @relation("reviewerReviews", fields: [reviewerId], references: [id])
  result     String         @db.VarChar(20) // APPROVED, REJECTED
  comment    String?        @db.Text // Bắt buộc nếu REJECTED
  reviewedAt DateTime       @default(now()) @map("reviewed_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  reviewComments ReviewComment[]

  @@index([reviewerId], map: "idx_course_reviews_reviewer")
  @@map("course_reviews")
}

model ReviewComment {
  id        String       @id @default(uuid()) @db.Char(36)
  reviewId  String       @map("review_id") @db.Char(36)
  review    CourseReview @relation(fields: [reviewId], references: [id])
  content   String       @db.Text
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([reviewId], map: "idx_review_comments_review")
  @@map("review_comments")
}

model MentorAssignment {
  id         String   @id @default(uuid()) @db.Char(36)
  mentorId   String   @map("mentor_id") @db.Char(36)
  mentor     User     @relation("mentorAssignments", fields: [mentorId], references: [id])
  courseId   String   @map("course_id") @db.Char(36)
  course     Course   @relation(fields: [courseId], references: [id])
  status     String   @default("ACTIVE") @db.VarChar(20)
  assignedAt DateTime @default(now()) @map("assigned_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([mentorId, courseId], map: "idx_mentor_assignment_unique")
  @@map("mentor_assignments")
}

model ProjectSubmission {
  id            String         @id @default(uuid()) @db.Char(36)
  learnerId     String         @map("learner_id") @db.Char(36)
  learner       User           @relation("submissions", fields: [learnerId], references: [id])
  courseId      String         @map("course_id") @db.Char(36)
  course        Course         @relation(fields: [courseId], references: [id])
  repositoryUrl String?        @map("repository_url") @db.VarChar(500)
  demoUrl       String?        @map("demo_url") @db.VarChar(500)
  note          String?        @db.Text
  attemptNo     Int            @default(1) @map("attempt_no")
  status        String         @default("PENDING") @db.VarChar(20)
  projectReview ProjectReview?
  submittedAt   DateTime       @default(now()) @map("submitted_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@unique([learnerId, courseId, attemptNo], map: "idx_submission_unique")
  @@map("project_submissions")
}

model ProjectReview {
  id           String            @id @default(uuid()) @db.Char(36)
  submissionId String            @unique @map("submission_id") @db.Char(36)
  submission   ProjectSubmission @relation(fields: [submissionId], references: [id])
  mentorId     String            @map("mentor_id") @db.Char(36)
  mentor       User              @relation("reviews", fields: [mentorId], references: [id])
  result       String            @db.VarChar(20)
  score        Decimal?          @db.Decimal(5, 2)
  feedback     String?           @db.Text
  feedbacks    MentorFeedback[]
  reviewedAt   DateTime          @default(now()) @map("reviewed_at")
  createdAt    DateTime          @default(now()) @map("created_at")

  @@map("project_reviews")
}

model MentorFeedback {
  id        String        @id @default(uuid()) @db.Char(36)
  reviewId  String        @map("review_id") @db.Char(36)
  review    ProjectReview @relation(fields: [reviewId], references: [id])
  mentorId  String        @map("mentor_id") @db.Char(36)
  message   String        @db.Text
  createdAt DateTime      @default(now()) @map("created_at")

  @@map("mentor_feedbacks")
}

model Rating {
  id        String   @id @default(uuid()) @db.Char(36)
  courseId  String   @map("course_id") @db.Char(36)
  course    Course   @relation(fields: [courseId], references: [id])
  userId    String   @map("user_id") @db.Char(36)
  user      User     @relation(fields: [userId], references: [id])
  score     Int // 1-5
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, courseId], map: "idx_rating_unique")
  @@index([courseId], map: "idx_ratings_course")
  @@map("ratings")
}

model Feedback {
  id        String   @id @default(uuid()) @db.Char(36)
  courseId  String   @map("course_id") @db.Char(36)
  course    Course   @relation(fields: [courseId], references: [id])
  userId    String   @map("user_id") @db.Char(36)
  user      User     @relation(fields: [userId], references: [id])
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([courseId], map: "idx_feedbacks_course")
  @@map("feedbacks")
}
