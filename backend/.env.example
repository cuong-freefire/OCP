# Backend environment draft for OCP Auth.
# Copy this file to backend/.env, then fill real values locally.
# Do not commit backend/.env because it may contain secrets.

# Runtime
PORT=5050
API_PREFIX=/api

# Frontend origin allowed by CORS.
# Must match the CRA dev server origin.
FRONTEND_ORIGIN=http://localhost:3000

# Prisma MySQL connection.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://ocp_user:ocp_password@localhost:3306/ocp"

# Existing project Auth/JWT secret.
AUTH_SECRET=replace_with_long_random_auth_secret

# Auth cookie names and local-dev cookie policy.
# Production should set COOKIE_SECURE=true.
COOKIE_ACCESS_NAME=ocp_access_token
COOKIE_REFRESH_NAME=ocp_refresh_token
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

# Token lifetimes.
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Password hashing.
BCRYPT_SALT_ROUNDS=12

# Email verification OTP.
EMAIL_OTP_EXPIRES_MINUTES=10
EMAIL_OTP_MAX_FAILED_ATTEMPTS=5
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60

# Reset password OTP.
RESET_OTP_EXPIRES_MINUTES=10
RESET_OTP_MAX_FAILED_ATTEMPTS=5
RESET_OTP_RESEND_COOLDOWN_SECONDS=60

# Nodemailer SMTP.
# SMTP_USER and SMTP_PASS are credentials. SMTP_HOST/PORT/SECURE are transport settings.
# For Gmail, use an app password in SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=OCP
# Use the same verified sender email as SMTP_USER unless your SMTP provider requires another sender.
SMTP_FROM_EMAIL=

# Google OAuth backend config.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Existing but not used by Nodemailer Auth MVP unless a later email provider spec says so.
RESEND_API_KEY=
