# Frontend environment draft for OCP Auth.
# Copy this file to frontend/.env, then fill real values locally.
# Create React App only exposes variables prefixed with REACT_APP_.
# Restart the CRA dev server after changing this file.

# CRA dev server port.
PORT=3000

# Backend API base URL.
# Must match backend PORT and API_PREFIX.
REACT_APP_API_BASE_URL=http://localhost:5050/api

# Google OAuth config is sourced from backend Auth config in the current contract
# (backend AUTH_GOOGLE_ID/AUTH_GOOGLE_SECRET). Do not add a separate frontend
# Google client ID requirement unless the Auth spec explicitly chooses direct
# Google Identity Services initialization in the CRA app.
